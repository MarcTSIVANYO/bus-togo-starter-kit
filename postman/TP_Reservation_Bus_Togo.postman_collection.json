    {
      "name": "Réservation - Créer réservation (PENDING + idempotence)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "pm.environment.set('reservationId', json.id);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          },
          {
            "key": "Idempotency-Key",
            "value": "demo-abc-123"
          }
        ],
        "url": {
          "raw": "{{baseRes}}/api/reservations",
